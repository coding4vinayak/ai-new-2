# OpenAI API Key for API-based extraction
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key for API-based extraction
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Path to Tesseract OCR binary
TESSERACT_PATH=/usr/bin/tesseract

# spaCy model name for local NER
SPACY_MODEL=en_core_web_sm

# SQLite database URL for audit logging
DATABASE_URL=sqlite:///data/audit.db

# Webhook secret for HMAC signing
WEBHOOK_SECRET=your-webhook-secret-here
