# OpenAI API Key for API-based extraction
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key for API-based extraction
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Path to Tesseract OCR binary
TESSERACT_PATH=/usr/bin/tesseract

# spaCy model name for local NER
SPACY_MODEL=en_core_web_sm

# SQLite database URL for audit logging
DATABASE_URL=sqlite:///data/audit.db

# Webhook secret for HMAC signing
WEBHOOK_SECRET=your-webhook-secret-here

# Local LLM settings (for OpenAI-compatible endpoints like Ollama, LM Studio, LocalAI)
# Base URL of the local LLM endpoint
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# Model name to use (e.g., llama3, mistral, phi3, codellama)
LOCAL_LLM_MODEL=llama3
# API key for the local endpoint (most local providers don't require one)
LOCAL_LLM_API_KEY=not-needed
